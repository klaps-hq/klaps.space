{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/*": [
        "./src/app/(frontend)/components/*"
      ],
      "@/lib/*": [
        "./src/app/(frontend)/lib/*"
      ],
      "@/hooks/*": [
        "./src/app/(frontend)/hooks/*"
      ],
      "@/contexts/*": [
        "./src/app/(frontend)/contexts/*"
      ],
      "@/constants": [
        "./src/app/(frontend)/constants/index.ts"
      ],
      "@/constants/*": [
        "./src/app/(frontend)/constants/*"
      ],
      "@/interfaces/*": [
        "./src/app/(frontend)/interfaces/*"
      ],
      "@/app/*": [
        "./src/app/*",
        "./src/app/(frontend)/*"
      ],
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}